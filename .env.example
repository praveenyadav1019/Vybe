# ─── Database ────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD is consumed by infra/docker-compose.yml (both the postgres
# container and the API's DATABASE_URL). Use a long random value in production
# and keep it in sync with DATABASE_URL below.
POSTGRES_PASSWORD=vybeon
DATABASE_URL=postgresql://vybeon:vybeon@localhost:5434/vybeon?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6381

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here!!
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── WebRTC TURN/STUN (self-hosted coturn) ───────────────────────────────────
# TURN_HOST = public IP or domain of your coturn server (reachable by clients).
# TURN_SECRET = coturn static-auth-secret (same value passed to the coturn container).
TURN_HOST=turn.example.com
TURN_SECRET=generate_a_long_random_secret
TURN_REALM=vybeon
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_TLS_ENABLED=false
# coturn container only (docker-compose): the server's public IP.
TURN_EXTERNAL_IP=your.public.ip.here
# The host's primary NIC address: `hostname -I | awk '{print $1}'`.
# On NAT'd cloud hosts (EC2/GCP) this differs from the public IP and coturn
# needs the PUBLIC/PRIVATE mapping. On a non-NAT VPS use the same value as
# TURN_EXTERNAL_IP.
TURN_PRIVATE_IP=your.private.ip.here

# NOTE: Twilio (SMS OTP) and Agora (RTC) were removed. Phone-OTP delivery now
# needs a new SMS provider wired in apps/api; Google Sign-In is the working login.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:8081,exp://localhost:8081

# ─── Location ────────────────────────────────────────────────────────────────
LOCATION_TTL_SECONDS=300

# ─── Storage (AWS S3 / Cloudflare R2) ────────────────────────────────────────
STORAGE_BUCKET=vybeon-media
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_access_key_here
STORAGE_SECRET_KEY=your_secret_key_here
STORAGE_CDN_URL=https://cdn.vybeon.com
