generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MatchRequestStatus {
  pending
  accepted
  rejected
}

enum CallType {
  audio
  video
}

enum CallStatus {
  ringing
  active
  ended
  rejected
  missed
}

enum VerificationStatus {
  none
  pending
  verified
  rejected
}

enum AppMode {
  dating
  hook
  co_travel
  night_out
  club_mates
  happening
}

enum SubscriptionPlan {
  free
  vybeon_plus
  vybeon_gold
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  pushToken String?
  isOnline  Boolean  @default(false)
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  profile       Profile?
  verification  Verification?
  location      UserLocation?
  otpCodes      OtpCode[]
  sessions      DeviceSession[]

  sentRequests     MatchRequest[] @relation("SentRequests")
  receivedRequests MatchRequest[] @relation("ReceivedRequests")

  chats    Chat[]       @relation("ChatUsers")
  messages Message[]
  calls    CallSession[] @relation("CallUsers")

  reportsMade  Report[] @relation("ReportsMade")
  reportsRecv  Report[] @relation("ReportsRecv")
  blocksMade   Block[]  @relation("BlocksMade")
  blocksRecv   Block[]  @relation("BlocksRecv")

  subscription  Subscription?
  notifications Notification[]
  checkins      PlaceCheckin[]
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  age       Int?
  gender    String?
  bio       String?
  interests String[] @default([])
  photos    String[] @default([])
  verified  Boolean  @default(false)
  mode      AppMode  @default(casual)
  safetyMode Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Verification {
  id            String             @id @default(cuid())
  userId        String             @unique
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        VerificationStatus @default(none)
  livenessScore Float?             @default(0)
  updatedAt     DateTime           @updatedAt
}

model UserLocation {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float
  lng       Float
  accuracy  Float?
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

model DeviceSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  deviceId     String
  deviceName   String?
  platform     String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model MatchRequest {
  id         String             @id @default(cuid())
  fromUserId String
  toUserId   String
  status     MatchRequestStatus @default(pending)
  message    String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  fromUser User @relation("SentRequests", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("ReceivedRequests", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
}

model Chat {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  users     User[]    @relation("ChatUsers")
  messages  Message[]

  @@index([createdAt])
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  content   String
  type      String   @default("text")
  mediaUrl  String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
}

model CallSession {
  id          String     @id @default(cuid())
  type        CallType
  status      CallStatus @default(ringing)
  channelName String?
  agoraToken  String?
  startedAt   DateTime?
  endedAt     DateTime?
  duration    Int?
  createdAt   DateTime   @default(now())

  users User[] @relation("CallUsers")

  @@index([createdAt])
}

model Place {
  id          String   @id @default(cuid())
  name        String
  lat         Float
  lng         Float
  category    String
  address     String?
  description String?
  tags        String[] @default([])
  photos      String[] @default([])
  isHappening Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activity  PlaceActivity?
  checkins  PlaceCheckin[]

  @@index([isHappening])
}

model PlaceActivity {
  placeId     String @id
  place       Place  @relation(fields: [placeId], references: [id], onDelete: Cascade)
  activeUsers Int    @default(0)
  vibeScore   Float  @default(0)
  crowdScore  Float  @default(0)
  updatedAt   DateTime @updatedAt
}

model PlaceCheckin {
  id        String   @id @default(cuid())
  placeId   String
  userId    String
  createdAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([placeId, createdAt])
}

model Report {
  id         String   @id @default(cuid())
  reporterId String
  targetId   String
  reason     String
  details    String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  reporter User @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  target   User @relation("ReportsRecv", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@index([reporterId])
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksRecv", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model Subscription {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @default(free)
  provider  String?
  productId String?
  startedAt DateTime         @default(now())
  expiresAt DateTime?
  createdAt DateTime         @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}
