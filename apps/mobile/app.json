{
  "expo": {
    "name": "VYBEON",
    "slug": "vybeon",
    "scheme": "vybeon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "cli": {
      "appVersionSource": "dynamic"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vybeon.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "VYBEON needs your location to find people nearby",
        "NSLocationAlwaysUsageDescription": "VYBEON uses your location in the background to keep you discoverable",
        "NSCameraUsageDescription": "VYBEON needs camera for profile verification and video calls",
        "NSMicrophoneUsageDescription": "VYBEON needs microphone for audio and video calls",
        "NSPhotoLibraryUsageDescription": "VYBEON needs photo access to upload profile pictures"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.vybeon.app",
      "versionCode": 1,
      "minSdkVersion": 30,
      "targetSdkVersion": 34,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.MAIN",
          "category": ["android.intent.category.LAUNCHER"]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 34
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "aa844fbe-5e73-49c6-a230-210cfb8ad8df"
      }
    }
  }
}
