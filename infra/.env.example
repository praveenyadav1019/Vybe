# API (copy to apps/api/.env or export before `npm run dev -w @vybeon/api`)
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://vybeon:vybeon@localhost:5432/vybeon?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=dev-change-me-please-16chars
LOCATION_TTL_SECONDS=300
CORS_ORIGIN=*

# Mobile — Expo public env
EXPO_PUBLIC_API_URL=http://localhost:4000
